#!/bin/bash
set -euo pipefail

RUNTIME_DIR="${MAILMAN_RUNTIME_DIR:-$HOME/.claude/scripts/mailman}"

if [ ! -d "$RUNTIME_DIR" ]; then
  echo "[mailman] runtime not found at $RUNTIME_DIR"
  echo "[mailman] install mailman first, or set MAILMAN_RUNTIME_DIR"
  exit 1
fi

# Codex CLI should not stomp on an existing Claude runtime unless the user opts in.
if [ -z "${MAILMAN_HOME:-}" ]; then
  export MAILMAN_HOME="$HOME/.mailman"
fi

command="${1:-fetch}"

case "$command" in
  auth)
    shift
    exec bash "$RUNTIME_DIR/run.sh" auth "$@"
    ;;
  collect|run)
    shift
    exec bash "$RUNTIME_DIR/run.sh" "$@"
    ;;
  fetch)
    shift
    exec bash "$RUNTIME_DIR/fetch.sh" "$@"
    ;;
  send)
    shift
    exec bash "$RUNTIME_DIR/send.sh" "$@"
    ;;
  help|-h|--help)
    cat <<'EOF'
mailman - Google Chat spec collector wrapper for Codex CLI

Usage:
  mailman [space] [bot] [count]
  mailman fetch [space] [bot] [count]
  mailman auth
  mailman run [space]
  mailman send <space>   # reads message body from stdin

Defaults:
  MAILMAN_RUNTIME_DIR = ~/.claude/scripts/mailman
  MAILMAN_HOME        = ~/.mailman
EOF
    ;;
  *)
    exec bash "$RUNTIME_DIR/fetch.sh" "$@"
    ;;
esac
